#!/bin/bash
# Sync version from root VERSION file to package.json and package-lock.json

# Read and trim whitespace from VERSION file
VERSION=$(cat "$(dirname "$0")/../VERSION" | tr -d '[:space:]')

cd "$(dirname "$0")/../frontend"

echo "🔄 Syncing version $VERSION to frontend files..."

# Update package.json with the version from VERSION file
if command -v jq &> /dev/null; then
    # Use jq if available (more reliable)
    jq --arg ver "$VERSION" '.version = $ver' package.json > package.json.tmp && mv package.json.tmp package.json
    echo "  ✅ Updated package.json"

    # Also update package-lock.json (has version in two places)
    if [ -f package-lock.json ]; then
        jq --arg ver "$VERSION" '.version = $ver | .packages."".version = $ver' package-lock.json > package-lock.json.tmp && mv package-lock.json.tmp package-lock.json
        echo "  ✅ Updated package-lock.json"
    fi
else
    # Fallback to sed
    sed -i "s/\"version\": \".*\"/\"version\": \"$VERSION\"/" package.json
    echo "  ✅ Updated package.json (using sed)"

    if [ -f package-lock.json ]; then
        sed -i "s/\"version\": \".*\"/\"version\": \"$VERSION\"/" package-lock.json
        echo "  ✅ Updated package-lock.json (using sed)"
    fi
fi

echo "✅ Version sync complete"
