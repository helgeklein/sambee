#!/bin/bash
# Sync version from root VERSION file to frontend and companion metadata files.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VERSION="$(tr -d '[:space:]' < "$REPO_ROOT/VERSION")"

if [ -z "$VERSION" ]; then
    echo "Error: VERSION file is empty"
    exit 1
fi

update_json_version() {
    local file="$1"
    local mode="$2"

    python3 - "$file" "$VERSION" "$mode" <<'PY'
import json
import sys
from pathlib import Path

file_path = Path(sys.argv[1])
version = sys.argv[2]
mode = sys.argv[3]

with file_path.open("r", encoding="utf-8") as handle:
    data = json.load(handle)

if mode == "package":
    data["version"] = version
elif mode == "package-lock":
    data["version"] = version
    packages = data.get("packages")
    if isinstance(packages, dict) and "" in packages and isinstance(packages[""], dict):
        packages[""]["version"] = version
else:
    raise SystemExit(f"Unsupported JSON sync mode: {mode}")

with file_path.open("w", encoding="utf-8") as handle:
    json.dump(data, handle, indent=2)
    handle.write("\n")
PY

    echo "  ✅ Updated $file"
}

update_package_json() {
    local file="$1"

    update_json_version "$file" "package"
}

update_package_lock_json() {
    local file="$1"

    if [ ! -f "$file" ]; then
        return
    fi

    update_json_version "$file" "package-lock"
}

update_cargo_toml() {
    local file="$1"
    local tmp
    tmp="$(mktemp)"

    awk -v ver="$VERSION" '
        BEGIN { in_package = 0; updated = 0 }
        /^\[package\]/ { in_package = 1; print; next }
        /^\[/ && !/^\[package\]/ { in_package = 0 }
        in_package && /^version[[:space:]]*=/ {
            print "version = \"" ver "\""
            updated = 1
            next
        }
        { print }
        END {
            if (!updated) {
                exit 2
            }
        }
    ' "$file" > "$tmp"

    mv "$tmp" "$file"
    echo "  ✅ Updated $file"
}

update_cargo_lock() {
    local file="$1"

    if [ ! -f "$file" ]; then
        return
    fi

    local tmp
    tmp="$(mktemp)"

    awk -v ver="$VERSION" '
        BEGIN { in_target_pkg = 0; updated = 0 }
        /^\[\[package\]\]$/ { in_target_pkg = 0; print; next }
        /^name = "sambee-companion"$/ { in_target_pkg = 1; print; next }
        in_target_pkg && /^version = "/ {
            print "version = \"" ver "\""
            updated = 1
            in_target_pkg = 0
            next
        }
        { print }
        END {
            if (!updated) {
                exit 2
            }
        }
    ' "$file" > "$tmp"

    mv "$tmp" "$file"
    echo "  ✅ Updated $file"
}

echo "🔄 Syncing version $VERSION across frontend and companion files..."

echo "Frontend:"
update_package_json "$REPO_ROOT/frontend/package.json"
update_package_lock_json "$REPO_ROOT/frontend/package-lock.json"

echo "Companion:"
update_package_json "$REPO_ROOT/companion/package.json"
update_package_lock_json "$REPO_ROOT/companion/package-lock.json"
update_cargo_toml "$REPO_ROOT/companion/src-tauri/Cargo.toml"
update_package_json "$REPO_ROOT/companion/src-tauri/tauri.conf.json"
update_cargo_lock "$REPO_ROOT/companion/src-tauri/Cargo.lock"

echo "✅ Version sync complete"
