#!/bin/bash
# Sync version from root VERSION file to frontend and companion metadata files.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VERSION="$(tr -d '[:space:]' < "$REPO_ROOT/VERSION")"

if [ -z "$VERSION" ]; then
    echo "Error: VERSION file is empty"
    exit 1
fi

update_json_version() {
    local file="$1"
    local mode="$2"

    python3 - "$file" "$VERSION" "$mode" <<'PY'
import json
import sys
from pathlib import Path

file_path = Path(sys.argv[1])
version = sys.argv[2]
mode = sys.argv[3]

with file_path.open("r", encoding="utf-8") as handle:
    data = json.load(handle)

if mode == "package":
    data["version"] = version
elif mode == "package-lock":
    data["version"] = version
    packages = data.get("packages")
    if isinstance(packages, dict) and "" in packages and isinstance(packages[""], dict):
        packages[""]["version"] = version
else:
    raise SystemExit(f"Unsupported JSON sync mode: {mode}")

with file_path.open("w", encoding="utf-8") as handle:
    json.dump(data, handle, indent=2, ensure_ascii=False)
    handle.write("\n")
PY

    echo "  ✅ Updated $file"
}

update_package_json() {
    local file="$1"

    update_json_version "$file" "package"
}

update_package_lock_json() {
    local file="$1"

    if [ ! -f "$file" ]; then
        return
    fi

    update_json_version "$file" "package-lock"
}

update_cargo_toml() {
    local file="$1"
    python3 - "$file" "$VERSION" <<'PY'
import sys
from pathlib import Path

file_path = Path(sys.argv[1])
version = sys.argv[2]

with file_path.open("r", encoding="utf-8", newline="") as handle:
    lines = handle.readlines()

in_package = False
updated = False

for index, line in enumerate(lines):
    stripped = line.strip()

    if stripped == "[package]":
        in_package = True
        continue

    if stripped.startswith("[") and stripped != "[package]":
        in_package = False

    if in_package and line.startswith("version"):
        newline = "\n"
        if line.endswith("\r\n"):
            newline = "\r\n"
        elif line.endswith("\n"):
            newline = "\n"
        elif line.endswith("\r"):
            newline = "\r"
        else:
            newline = ""

        lines[index] = f'version = "{version}"{newline}'
        updated = True
        break

if not updated:
    raise SystemExit(2)

with file_path.open("w", encoding="utf-8", newline="") as handle:
    handle.writelines(lines)
PY

    echo "  ✅ Updated $file"
}

update_cargo_lock() {
    local file="$1"

    if [ ! -f "$file" ]; then
        return
    fi

    python3 - "$file" "$VERSION" <<'PY'
import sys
from pathlib import Path

file_path = Path(sys.argv[1])
version = sys.argv[2]

with file_path.open("r", encoding="utf-8", newline="") as handle:
    lines = handle.readlines()

in_target_pkg = False
updated = False

for index, line in enumerate(lines):
    stripped = line.strip()

    if stripped == "[[package]]":
        in_target_pkg = False
        continue

    if stripped == 'name = "sambee-companion"':
        in_target_pkg = True
        continue

    if in_target_pkg and stripped.startswith('version = "'):
        newline = "\n"
        if line.endswith("\r\n"):
            newline = "\r\n"
        elif line.endswith("\n"):
            newline = "\n"
        elif line.endswith("\r"):
            newline = "\r"
        else:
            newline = ""

        lines[index] = f'version = "{version}"{newline}'
        updated = True
        break

if not updated:
    raise SystemExit(2)

with file_path.open("w", encoding="utf-8", newline="") as handle:
    handle.writelines(lines)
PY

    echo "  ✅ Updated $file"
}

echo "🔄 Syncing version $VERSION across frontend and companion files..."

echo "Frontend:"
update_package_json "$REPO_ROOT/frontend/package.json"
update_package_lock_json "$REPO_ROOT/frontend/package-lock.json"

echo "Companion:"
update_package_json "$REPO_ROOT/companion/package.json"
update_package_lock_json "$REPO_ROOT/companion/package-lock.json"
update_cargo_toml "$REPO_ROOT/companion/src-tauri/Cargo.toml"
update_package_json "$REPO_ROOT/companion/src-tauri/tauri.conf.json"
update_cargo_lock "$REPO_ROOT/companion/src-tauri/Cargo.lock"

echo "✅ Version sync complete"
