#!/bin/bash
# Centralized system dependencies installation script
# Used by: Devcontainer, Dockerfile, GitHub Actions

set -e

# Detect if we're on Ubuntu or Debian to use the correct libjpeg package
if grep -q "Ubuntu" /etc/os-release 2>/dev/null; then
    LIBJPEG_PKG="libjpeg-turbo8"
else
    LIBJPEG_PKG="libjpeg62-turbo"
fi

# Common packages required for Sambee (runtime dependencies only)
# - libmagic1: File type detection (python-magic)
# - libvips42: Image processing library (pyvips runtime)
# - libheif1: HEIC/HEIF image format support
# - libjpeg-turbo8/libjpeg62-turbo: JPEG library (Ubuntu/Debian naming difference)
# - libpng16-16, libtiff6, libwebp7, libgif7, libexif12: Image format libraries
# - ghostscript: PostScript/PDF interpreter (required for EPS, AI, PS, PDF processing via ImageMagick)
# - libgs-common: Ghostscript ICC color profiles for proper CMYK→RGB conversion
SAMBEE_SYSTEM_PACKAGES=(
    libmagic1
    libvips42
    libheif1
    "${LIBJPEG_PKG}"
    libpng16-16
    libtiff6
    libwebp7
    libgif7
    libexif12
    ghostscript
    libgs-common
    wget
)

MAGICK_SYSTEM_PACKAGE="imagemagick"
MAGICK_VERSIONED_SYSTEM_PACKAGE="imagemagick-7.q16"

install_imagemagick_from_package_manager() {
    local package_to_install="$MAGICK_SYSTEM_PACKAGE"

    if apt-cache show "$MAGICK_VERSIONED_SYSTEM_PACKAGE" >/dev/null 2>&1; then
        package_to_install="$MAGICK_VERSIONED_SYSTEM_PACKAGE"
    fi

    echo "Installing ImageMagick from the distro package manager (${package_to_install})..."
    apt-get install -y "$package_to_install"
    verify_imagemagick7_command >/dev/null
}

verify_imagemagick7_command() {
    local version_output=""

    if command -v magick >/dev/null 2>&1; then
        version_output="$(magick --version 2>/dev/null | head -1)"
    elif command -v convert >/dev/null 2>&1; then
        version_output="$(convert --version 2>/dev/null | head -1)"
    fi

    if [[ -z "$version_output" ]]; then
        echo "ImageMagick verification failed: no runnable magick or convert command found after installation." >&2
        return 1
    fi

    if [[ "$version_output" != *"ImageMagick 7."* ]]; then
        echo "ImageMagick verification failed: expected major version 7.x, got: $version_output" >&2
        return 1
    fi

    echo "$version_output"
}

# Install ImageMagick 7 from distro packages
install_imagemagick7() {
    install_imagemagick_from_package_manager
}

# Function to install packages
install_packages() {
    echo "Installing Sambee system dependencies..."
    echo "Using ${LIBJPEG_PKG} for libjpeg-turbo"
    # Skip apt-get update if caller already ran it (e.g. CI combining steps)
    if [ "${SKIP_APT_UPDATE:-0}" != "1" ]; then
        apt-get update
    fi
    if [ "${UPGRADE_EXISTING_PACKAGES:-0}" = "1" ]; then
        echo "Refreshing already-installed apt packages before dependency install..."
        apt-get upgrade -y
    fi
    apt-get install -y "${SAMBEE_SYSTEM_PACKAGES[@]}"

    # Install ImageMagick 7
    install_imagemagick7

    rm -rf /var/lib/apt/lists/*
    echo "✓ All system dependencies installed successfully"
}

# If script is executed (not sourced), run installation
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    install_packages
fi
