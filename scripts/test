#!/bin/bash
set -euo pipefail

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Get the repository root (parent of scripts directory)
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

BACKEND_DIR="$REPO_ROOT/backend"
BACKEND_VENV="$BACKEND_DIR/.venv"
BACKEND_PYTHON="$BACKEND_VENV/bin/python"
BACKEND_LOCKFILE="$BACKEND_DIR/requirements-dev.lock.txt"
BACKEND_LOCK_STAMP="$BACKEND_VENV/.requirements-dev.lock.sha256"

require_backend_venv() {
    if [ ! -x "$BACKEND_PYTHON" ]; then
        echo -e "${RED}✗ Backend virtual environment not found at backend/.venv${NC}"
        echo -e "${YELLOW}Run scripts/setup-backend-venv to install the pinned backend dependencies.${NC}"
        exit 1
    fi

    if [ ! -f "$BACKEND_LOCK_STAMP" ]; then
        echo -e "${RED}✗ Backend virtual environment is missing its lockfile stamp${NC}"
        echo -e "${YELLOW}Run scripts/setup-backend-venv to rebuild backend/.venv from pinned dependencies.${NC}"
        exit 1
    fi

    current_lock_hash="$(sha256sum "$BACKEND_LOCKFILE" | awk '{print $1}')"
    recorded_lock_hash="$(cat "$BACKEND_LOCK_STAMP")"

    if [ "$current_lock_hash" != "$recorded_lock_hash" ]; then
        echo -e "${RED}✗ Backend virtual environment is stale: requirements-dev.lock.txt changed${NC}"
        echo -e "${YELLOW}Run scripts/setup-backend-venv to rebuild backend/.venv with the updated pinned dependencies.${NC}"
        exit 1
    fi
}

echo -e "${BLUE}======================================${NC}"
echo -e "${BLUE}  Sambee - Test & Analysis Suite${NC}"
echo -e "${BLUE}======================================${NC}\n"

require_backend_venv

# Track overall status
OVERALL_STATUS=0

# ============================================
# SETUP: Generate Test Images
# ============================================
echo -e "${YELLOW}=== Setup: Generating Test Images ===${NC}"
if QUIET=1 "$SCRIPT_DIR/setup-test-images"; then
    echo -e "${GREEN}✓ Test images generated${NC}\n"
else
    echo -e "${RED}✗ Failed to generate test images${NC}\n"
    OVERALL_STATUS=1
fi

# ============================================
# BACKEND TESTS
# ============================================
echo -e "${YELLOW}=== Backend: Static Analysis ===${NC}"
cd "$BACKEND_DIR" || exit 1

# mypy - Type checking (non-fatal, just warnings)
echo -e "${BLUE}Running mypy (type checking)...${NC}"
if "$BACKEND_PYTHON" -m mypy app; then
    echo -e "${GREEN}✓ mypy passed${NC}\n"
else
    echo -e "${YELLOW}⚠ mypy found issues (non-fatal)${NC}\n"
    # Don't fail on mypy errors as they're just type hints
fi

# Backend: Unit Tests
echo -e "${YELLOW}=== Backend: Unit Tests ===${NC}"
echo -e "${BLUE}Running pytest (excluding performance tests)...${NC}"

# Determine number of workers for parallel execution
# Use number of CPU cores, or default to 4
NUM_WORKERS="${PYTEST_WORKERS:-auto}"

# Show parallel execution info
if [ "$NUM_WORKERS" = "auto" ]; then
    echo -e "${BLUE}Parallel execution: auto-detect CPU cores${NC}"
else
    echo -e "${BLUE}Parallel execution: $NUM_WORKERS workers${NC}"
fi

# Use coverage only if COVERAGE env var is set
if [ "${COVERAGE:-0}" = "1" ]; then
    # Coverage with parallel execution
    PYTEST_CMD=("$BACKEND_PYTHON" -m pytest -n "$NUM_WORKERS" -m "not performance" --cov=app --cov-report=term-missing --cov-report=html --cov-report=xml)
    echo -e "${BLUE}Coverage: enabled${NC}"
else
    # Parallel execution without coverage (fastest)
    PYTEST_CMD=("$BACKEND_PYTHON" -m pytest -n "$NUM_WORKERS" -m "not performance")
    echo -e "${BLUE}Coverage: disabled${NC}"
fi

if "${PYTEST_CMD[@]}"; then
    echo -e "${GREEN}✓ Backend tests passed${NC}\n"
else
    echo -e "${RED}✗ Backend tests failed${NC}\n"
    OVERALL_STATUS=1
fi

echo -e "${YELLOW}=== Backend: Performance Tests ===${NC}"
echo -e "${BLUE}Running performance tests serially...${NC}"

if [ "${COVERAGE:-0}" = "1" ]; then
    PERFORMANCE_PYTEST_CMD=("$BACKEND_PYTHON" -m pytest -m performance --cov=app --cov-append --cov-report=term-missing --cov-report=html --cov-report=xml)
else
    PERFORMANCE_PYTEST_CMD=("$BACKEND_PYTHON" -m pytest -m performance)
fi

if "${PERFORMANCE_PYTEST_CMD[@]}"; then
    echo -e "${GREEN}✓ Backend performance tests passed${NC}\n"
else
    echo -e "${RED}✗ Backend performance tests failed${NC}\n"
    OVERALL_STATUS=1
fi

# ============================================
# FRONTEND TESTS
# ============================================
echo -e "${YELLOW}=== Frontend: Static Analysis ===${NC}"
cd "$REPO_ROOT/frontend" || exit 1

# TypeScript - Type checking
echo -e "${BLUE}Running TypeScript compiler (type checking)...${NC}"
if npx tsc --noEmit; then
    echo -e "${GREEN}✓ TypeScript type check passed${NC}\n"
else
    echo -e "${RED}✗ TypeScript type check failed${NC}\n"
    OVERALL_STATUS=1
fi

# Frontend: Unit Tests (if they exist)
if grep -q '"test"' package.json; then
    echo -e "${YELLOW}=== Frontend: Unit Tests ===${NC}"
    echo -e "${BLUE}Running frontend tests...${NC}"
    FRONTEND_TEST_SCRIPT="${FRONTEND_TEST_SCRIPT:-}"
    if [ -z "$FRONTEND_TEST_SCRIPT" ]; then
        if [ "${CI:-}" = "true" ]; then
            FRONTEND_TEST_SCRIPT="test:ci"
        else
            FRONTEND_TEST_SCRIPT="test"
        fi
    fi

    echo -e "${BLUE}Using frontend npm script: ${FRONTEND_TEST_SCRIPT}${NC}"
    if npm run "$FRONTEND_TEST_SCRIPT"; then
        echo -e "${GREEN}✓ Frontend tests passed${NC}\n"
    else
        echo -e "${RED}✗ Frontend tests failed${NC}\n"
        OVERALL_STATUS=1
    fi
fi

# ============================================
# COMPANION TESTS
# ============================================
if [ -d "$REPO_ROOT/companion/src-tauri" ]; then
    echo -e "${YELLOW}=== Companion: Static Analysis ===${NC}"
    cd "$REPO_ROOT/companion" || exit 1

    # TypeScript - Type checking
    echo -e "${BLUE}Running TypeScript compiler (companion type checking)...${NC}"
    if npx tsc --noEmit; then
        echo -e "${GREEN}✓ Companion TypeScript type check passed${NC}\n"
    else
        echo -e "${RED}✗ Companion TypeScript type check failed${NC}\n"
        OVERALL_STATUS=1
    fi

    echo -e "${YELLOW}=== Companion: Windows Cross-Check ===${NC}"
    echo -e "${BLUE}Running Windows GNU target cargo check...${NC}"
    if [ "${CI:-}" = "true" ]; then
        echo -e "${YELLOW}⚠ Companion Windows cross-check skipped in CI${NC}\n"
    elif command -v x86_64-w64-mingw32-gcc >/dev/null 2>&1 \
        && rustup target list --installed 2>/dev/null | grep -q '^x86_64-pc-windows-gnu$'; then
        if npm run check:rust:windows; then
            echo -e "${GREEN}✓ Companion Windows cross-check passed${NC}\n"
        else
            echo -e "${RED}✗ Companion Windows cross-check failed${NC}\n"
            OVERALL_STATUS=1
        fi
    else
        echo -e "${YELLOW}⚠ Companion Windows cross-check skipped (missing x86_64-pc-windows-gnu target or MinGW toolchain)${NC}\n"
    fi

    echo -e "${YELLOW}=== Companion: Rust Tests ===${NC}"
    cd "$REPO_ROOT/companion/src-tauri" || exit 1

    echo -e "${YELLOW}=== Companion: Clippy ===${NC}"
    echo -e "${BLUE}Running cargo clippy (--lib --tests -D warnings)...${NC}"
    if cargo clippy --lib --tests -- -D warnings 2>&1; then
        echo -e "${GREEN}✓ Companion Clippy passed${NC}\n"
    else
        echo -e "${RED}✗ Companion Clippy failed${NC}\n"
        OVERALL_STATUS=1
    fi

    echo -e "${BLUE}Running cargo test...${NC}"
    if cargo test 2>&1; then
        echo -e "${GREEN}✓ Companion Rust tests passed${NC}\n"
    else
        echo -e "${RED}✗ Companion Rust tests failed${NC}\n"
        OVERALL_STATUS=1
    fi
fi

# ============================================
# SUMMARY
# ============================================
echo -e "${BLUE}======================================${NC}"
if [ $OVERALL_STATUS -eq 0 ]; then
    echo -e "${GREEN}✓ All tests and checks passed!${NC}"
    echo -e "${BLUE}======================================${NC}"
    exit 0
else
    echo -e "${RED}✗ Some tests or checks failed!${NC}"
    echo -e "${BLUE}======================================${NC}"
    exit 1
fi
