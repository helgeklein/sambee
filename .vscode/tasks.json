{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Start Dev Server",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/start-backend",
      "options": {
        "env": {
          "PYTHONPATH": "${workspaceFolder}/backend"
        }
      },
      "group": "build",
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "development",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Start Dev Server",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/start-frontend",
      "group": "build",
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "development",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: Run Tests",
      "type": "shell",
      "command": "pytest -v",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Backend: Type Check (mypy)",
      "type": "shell",
      "command": "mypy app",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": {
        "owner": "mypy",
        "source": "mypy",
        "fileLocation": [
          "relative",
          "${workspaceFolder}/backend"
        ],
        "pattern": {
          "regexp": "^(.+?):(\\d+):(\\d+:)? (error|warning|note): (.+?)\\s*\\[(.+?)\\]$",
          "file": 1,
          "line": 2,
          "severity": 4,
          "message": 5,
          "code": 6
        }
      }
    },
    {
      "label": "Frontend: Run Tests",
      "type": "npm",
      "script": "test",
      "path": "frontend/",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Companion: Run Rust Tests",
      "type": "shell",
      "command": "cargo test",
      "options": {
        "cwd": "${workspaceFolder}/companion/src-tauri"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Companion: Type Check + Lint",
      "type": "shell",
      "command": "npx tsc --noEmit 2>&1 && echo '✓ TypeScript type check passed' && cd src-tauri && cargo clippy --lib --tests -- -D warnings 2>&1 && echo '✓ Clippy passed' && RUSTFLAGS='-A dead_code' cargo check --target x86_64-pc-windows-gnu 2>&1 && echo '✓ Windows cross-check passed' && cargo fmt --check 2>&1 && echo '✓ Rust formatting OK' && cd .. && npm run lint 2>&1 && echo '✓ Biome lint passed' && echo '' && echo '══════════════════════════════════' && echo '  All companion checks passed ✓' && echo '══════════════════════════════════'",
      "options": {
        "cwd": "${workspaceFolder}/companion"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Database: Reset",
      "type": "shell",
      "command": "rm -f data/sambee.db && python -c 'from app.db.database import init_db; init_db()'",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}