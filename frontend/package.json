{
  "name": "sambee-frontend",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "postinstall": "node scripts/patch-react-transition-group.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:e2e:smoke": "playwright test --project=chromium e2e/markdown-viewer.spec.ts",
    "test:e2e:markdown": "playwright test --project=chromium e2e/markdown-viewer.spec.ts",
    "test:e2e:firefox": "playwright test --project=firefox e2e/markdown-viewer.spec.ts",
    "test:e2e:debug": "playwright test --project=chromium --headed --debug",
    "test:e2e:install": "playwright install chromium firefox",
    "test:changed": "vitest run --changed",
    "test:watch:changed": "vitest --changed"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mdxeditor/editor": "^4.0.4",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@react-spring/web": "^10.1.2",
    "@tanstack/react-virtual": "^3.14.4",
    "@use-gesture/react": "^10.3.1",
    "axios": "1.18.1",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-photo-view": "^1.2.7",
    "react-router-dom": "^7.18.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "swiper": "^14.0.0",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "8.1.0",
    "vitest": "^4.1.0"
  }
}
