    "@react-spring/web": "^10.0.3",
    "@tanstack/react-virtual": "^3.13.22",
    "@use-gesture/react": "^10.3.1",
    "axios": "^1.13.6",
    "i18next": "^25.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-markdown": "^9.1.0",
