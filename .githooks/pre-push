#!/usr/bin/env bash
#
# pre-push
#
# Block pushes of work-in-progress branches.

set -euo pipefail

remote_name=${1:-unknown}
remote_url=${2:-unknown}

while read -r local_ref local_sha remote_ref remote_sha; do
    branch_ref=""

    case "$local_ref" in
        refs/heads/wip/*) branch_ref=$local_ref ;;
    esac

    case "$remote_ref" in
        refs/heads/wip/*) branch_ref=${branch_ref:-$remote_ref} ;;
    esac

    if [[ -n "$branch_ref" ]]; then
        branch_name=${branch_ref#refs/heads/}
        echo "Push blocked: branches starting with 'wip/' cannot be pushed to remotes." >&2
        echo "Branch: $branch_name" >&2
        echo "Remote: $remote_name ($remote_url)" >&2
        exit 1
    fi
done

exit 0
