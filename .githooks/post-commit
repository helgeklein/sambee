#!/usr/bin/env bash
#
# post-commit
#
# Git hook to automatically update GIT_COMMIT file after each commit
# while preserving Git LFS post-commit behavior.

set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Get the short commit hash of HEAD (the commit that just completed)
GIT_COMMIT=$(git rev-parse --short HEAD)

# Write to GIT_COMMIT file in repository root
echo "$GIT_COMMIT" > GIT_COMMIT

# Note: The hash in GIT_COMMIT will be the PREVIOUS commit's hash
# This is intentional - it represents "last known commit" at build time

"$HOOK_DIR/_git-lfs-hook" post-commit "$@"
