{
  "name": "sambee-companion",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "clean": "npm run clean:rust && rm -rf dist",
    "clean:rust": "cargo clean --manifest-path src-tauri/Cargo.toml",
    "check:rust:windows": "mkdir -p src-tauri/target/windows-gnu-check && CARGO_TARGET_DIR=src-tauri/target/windows-gnu-check RUSTFLAGS='-A dead_code' cargo check --manifest-path src-tauri/Cargo.toml --target x86_64-pc-windows-gnu",
    "test": "vitest run",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "i18next": "25.10.10",
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@preact/preset-vite": "2.10.5",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "jsdom": "29.0.2",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "vitest": "^4.1.4"
  }
}
