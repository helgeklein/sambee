# Git LFS configuration for website media assets.
# Strict donor parity: source images, generated WebP derivatives, and
# Hugo's cached processed images are committed and fetched via Git LFS.

website/assets/images/** filter=lfs diff=lfs merge=lfs -text
website/resources/_gen/images/** filter=lfs diff=lfs merge=lfs -text
website/static/files/** filter=lfs diff=lfs merge=lfs -text
